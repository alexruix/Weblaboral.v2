{
  "name": "fintech-platform",
  "version": "0.1.0",
  "description": "Corporate-futuristic fintech platform built with Astro + Tailwind + GSAP + Lenis",
  "type": "module",
  "scripts": {
    "dev": "npm run tokens && astro dev",
    "build": "npm run tokens && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "tokens": "node scripts/build-tokens.mjs",
    "tokens:watch": "node --watch scripts/build-tokens.mjs",
    "lint": "eslint src --ext .ts,.astro",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.18.0",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/gsap": "^3.0.0",
    "tailwindcss": "^3.4.19"
  }
}
