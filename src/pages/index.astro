---
/**
 * src/pages/index.astro — Agency Homepage
 *
 * Design philosophy: Neo-Minimalista · Modern Tech · Conversion-Focused
 * Reference content: tradeweb.com.ar (content only, redesigned from scratch)
 *
 * Sections:
 *  1. Hero           — Massive type + parallax + CTA shimmer
 *  2. Trust Ticker   — Greyscale → color logo loop (GSAP)
 *  3. Services Bento — Magnetic card hover grid
 *  4. Portfolio Reel — Horizontal GSAP scroll section
 *  5. Stats Bar      — 3 animated counters with ScrollTrigger
 *  6. Testimonials   — Two-column trust grid
 *  7. Contact Form   — Glassmorphism, inline validation
 */

import Layout          from '@layouts/Layout.astro';
import Navbar          from '@organisms/Navbar.astro';
import Footer          from '@organisms/Footer.astro';
import TrustTicker     from '@organisms/TrustTicker.astro';
import Button          from '@atoms/Button.astro';
import Icon            from '@atoms/Icon.astro';
import ServiceCard     from '@molecules/ServiceCard.astro';
import TestimonialCard from '@molecules/TestimonialCard.astro';

// ── Nav
const navLinks = [
  {
    label: 'Servicios',
    items: [
      { label: 'Diseño Web',       href: '#servicios' },
      { label: 'Marketing Digital', href: '#servicios' },
      { label: 'Branding',          href: '#servicios' },
    ],
  },
  { label: 'Portfolio', href: '#portfolio' },
  { label: 'Nosotros',  href: '#nosotros'  },
  { label: 'Contacto',  href: '#contacto'  },
];

// ── Services
const services = [
  // — Web Design (col-span-2 bento)
  {
    id: 'landing',
    title: 'Landing Pages',
    description: 'Páginas de alta conversión diseñadas para transformar visitantes en clientes. Estrategia, diseño y copy integrados.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    tag: 'Diseño Web',
    stat: { value: '+340%', label: 'Conversión promedio de nuestros clientes' },
    href: '/servicios/landing-pages',
    ctaText: 'Ver servicio →',
    accent: '#0CF2D0',
    bento: 'col-span-1 md:col-span-2',
  },
  {
    id: 'ecommerce',
    title: 'E-Commerce',
    description: 'Tiendas online que venden las 24hs. Integramos medios de pago, logística y gestión de stock.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>',
    tag: 'Diseño Web',
    href: '/servicios/ecommerce',
    ctaText: 'Explorar →',
    accent: '#1B6FFF',
    bento: 'col-span-1',
  },
  {
    id: 'hoteles',
    title: 'Sitios para Hoteles',
    description: 'Motor de reservas directo, galería inmersiva y posicionamiento en Google Hotel Ads.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
    tag: 'Diseño Web',
    href: '/servicios/hoteles',
    ctaText: 'Explorar →',
    accent: '#9B5DE5',
    bento: 'col-span-1',
  },
  // — Marketing
  {
    id: 'seo',
    title: 'SEO Estratégico',
    description: 'Posicionamiento orgánico moderno: auditorías técnicas, contenido semántico y link building con datos reales.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    tag: 'Marketing',
    stat: { value: 'Top 3', label: 'Posición media en Google' },
    href: '/servicios/seo',
    ctaText: 'Ver resultados →',
    accent: '#22D35A',
    bento: 'col-span-1',
  },
  {
    id: 'ads',
    title: 'Google & Meta Ads',
    description: 'Campañas de alto rendimiento con optimización diaria. Cada peso invertido tiene tracking y retorno medible.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>',
    tag: 'Marketing',
    href: '/servicios/ads',
    ctaText: 'Explorar →',
    accent: '#F5A623',
    bento: 'col-span-1 md:col-span-2',
  },
  // — Branding
  {
    id: 'branding',
    title: 'Identidad Visual',
    description: 'Logo, paleta, tipografía y manual de marca. Una identidad coherente multiplica el valor percibido de tu negocio.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>',
    tag: 'Branding',
    stat: { value: '12 años', label: 'Creando marcas memorables' },
    href: '/servicios/branding',
    ctaText: 'Ver proceso →',
    accent: '#FF3B5C',
    bento: 'col-span-1 md:col-span-2',
  },
];

// ── Portfolio projects
const portfolio = [
  {
    id: 'p1',
    title: 'Nómade Hoteles',
    category: 'Diseño Web · Hoteles',
    year: '2024',
    accent: '#0CF2D0',
    bg: '#041A18',
    desc: 'Rediseño completo con motor de reservas directo y +60% conversión orgánica.',
  },
  {
    id: 'p2',
    title: 'Malbec Roots Winery',
    category: 'E-Commerce · Branding',
    year: '2024',
    accent: '#9B5DE5',
    bg: '#110A1E',
    desc: 'Tienda online B2C y B2B para exportación de vino a 12 países.',
  },
  {
    id: 'p3',
    title: 'FitPlan Pro',
    category: 'Landing Page · Meta Ads',
    year: '2023',
    accent: '#F5A623',
    bg: '#1A1000',
    desc: 'Landing + funnel de ventas con ROAS 4.2× en 60 días de campaña.',
  },
  {
    id: 'p4',
    title: 'Clínica Belgrano',
    category: 'Diseño Web · SEO',
    year: '2023',
    accent: '#22D35A',
    bg: '#051510',
    desc: 'De página 4 a Top 3 de Google en 3 meses para keywords clave.',
  },
];

// ── Testimonials
const testimonials = [
  {
    quote: 'En 45 días lanzamos la tienda, y en el primer mes superamos las ventas físicas. TradeWeb entiende el negocio antes que el diseño.',
    author: 'Sofía Carranza',
    role: 'Fundadora',
    company: 'Malbec Roots Winery',
    rating: 5,
    accent: '#9B5DE5',
    result: { value: '+320%', label: 'ventas online en 90 días' },
    featured: true,
  },
  {
    quote: 'Duplicamos las reservas directas del hotel en una temporada. El diseño genera confianza instantánea en el viajero internacional.',
    author: 'Marcos Delgado',
    role: 'Director de Marketing',
    company: 'Nómade Hoteles',
    rating: 5,
    accent: '#0CF2D0',
  },
  {
    quote: 'Teníamos una web vieja y nadie nos encontraba. Ahora somos el primer resultado de Google para nuestra especialidad en Córdoba.',
    author: 'Dra. Cecilia Rojas',
    role: 'Directora Médica',
    company: 'Clínica Belgrano',
    rating: 5,
    accent: '#22D35A',
    result: { value: 'Posición #1', label: 'Google Córdoba' },
    featured: true,
  },
  {
    quote: 'El equipo propuso ideas que nosotros jamás habríamos pensado. La marca quedó coherente en todos los canales por primera vez.',
    author: 'Juan Mercado',
    role: 'CEO',
    company: 'FitPlan Pro',
    rating: 5,
    accent: '#F5A623',
  },
];

// ── Stats
const stats = [
  { value: 12,   suffix: '',       label: 'años en el mercado',        accent: '#0CF2D0' },
  { value: 280,  suffix: '+',      label: 'proyectos entregados',      accent: '#1B6FFF' },
  { value: 98,   suffix: '%',      label: 'clientes que recomiendan',  accent: '#9B5DE5' },
  { value: 4.8,  suffix: '× ROI',  label: 'retorno promedio en Ads',   accent: '#F5A623', decimals: 1 },
];

// ── Footer columns
const footerColumns = [
  {
    heading: 'Servicios',
    links: [
      { label: 'Landing Pages',    href: '/servicios/landing-pages' },
      { label: 'E-Commerce',       href: '/servicios/ecommerce' },
      { label: 'Sitios para Hoteles', href: '/servicios/hoteles' },
      { label: 'SEO Estratégico',  href: '/servicios/seo' },
      { label: 'Google & Meta Ads', href: '/servicios/ads' },
      { label: 'Identidad Visual', href: '/servicios/branding' },
    ],
  },
  {
    heading: 'Empresa',
    links: [
      { label: 'Nosotros',    href: '#nosotros' },
      { label: 'Portfolio',   href: '#portfolio' },
      { label: 'Blog',        href: '/blog' },
      { label: 'Testimonios', href: '#testimonios' },
    ],
  },
  {
    heading: 'Contacto',
    links: [
      { label: 'WhatsApp',    href: 'https://wa.me/5493515000000', external: true, badge: 'Rápido' },
      { label: 'Email',       href: 'mailto:hola@tradeweb.com.ar', external: true },
      { label: 'Presupuesto', href: '#contacto' },
    ],
  },
];
---

<Layout
  seo={{
    title: 'TradeWeb — Soluciones Digitales en Córdoba | Diseño Web, SEO y Marketing',
    description: '12 años transformando marcas con Diseño Web Premium, Marketing Estratégico e Identidad Visual en Córdoba y el mundo. Más de 280 proyectos entregados.',
    ogType: 'website',
    jsonLd: {
      '@type': 'ProfessionalService',
      name: 'TradeWeb',
      description: 'Agencia digital especializada en diseño web, SEO, publicidad digital e identidad visual en Córdoba, Argentina.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Córdoba',
        addressCountry: 'AR',
      },
      url: 'https://tradeweb.com.ar',
      telephone: '+543515000000',
      priceRange: '$$',
      areaServed: ['Argentina', 'Latinoamérica'],
    },
  }}
>
  <Navbar slot="navbar" links={navLinks} currentPath="/" logoText="TradeWeb" />

  <!-- ═══════════════════════════════════════════════════════
       §1  HERO
  ══════════════════════════════════════════════════════════ -->
  <section
    id="hero"
    class="relative min-h-screen flex items-center overflow-hidden"
    aria-label="Hero"
  >
    <!-- GSAP-driven parallax bg elements — animated via script below -->
    <div id="hero-grid" aria-hidden="true" class="absolute inset-0 pointer-events-none will-change-transform"
      style="background-image: linear-gradient(rgba(12,242,208,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(12,242,208,0.025) 1px, transparent 1px); background-size: 72px 72px;"
    />
    <div id="hero-glow-1" aria-hidden="true" class="absolute pointer-events-none will-change-transform"
      style="top: -20%; right: -10%; width: 70vw; height: 70vw; background: radial-gradient(circle, rgba(12,242,208,0.06) 0%, transparent 65%); border-radius: 50%;"
    />
    <div id="hero-glow-2" aria-hidden="true" class="absolute pointer-events-none will-change-transform"
      style="bottom: -10%; left: -15%; width: 60vw; height: 60vw; background: radial-gradient(circle, rgba(27,111,255,0.05) 0%, transparent 65%); border-radius: 50%;"
    />

    <!-- Scan-line decoration -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="animate-scan-line absolute left-0 right-0 h-px opacity-10"
        style="background: linear-gradient(90deg, transparent, #0CF2D0, transparent);"
      />
    </div>

    <div class="container-site relative z-base w-full pt-28 pb-20">
      <div class="max-w-5xl">

        <!-- Eyebrow -->
        <div data-reveal="up" class="flex items-center gap-3 mb-10">
          <span class="section-eyebrow">
            <span class="relative flex w-2 h-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-60"></span>
              <span class="relative inline-flex rounded-full w-2 h-2 bg-brand-primary"></span>
            </span>
            Córdoba, Argentina · +280 proyectos
          </span>
        </div>

        <!-- Headline — massif -->
        <h1
          id="hero-headline"
          data-reveal="up"
          data-reveal-delay="0.05"
          class="font-display font-extrabold text-primary mb-8"
          style="font-size: clamp(2.8rem, 7vw, 5.5rem); letter-spacing: -0.04em; line-height: 1.0; text-wrap: balance;"
        >
          Soluciones Digitales<br/>
          que <span class="text-gradient">Escalan</span><br/>
          tu Negocio.
        </h1>

        <!-- Subheadline -->
        <p
          data-reveal="up"
          data-reveal-delay="0.12"
          class="text-secondary text-xl leading-relaxed max-w-2xl mb-12"
          style="text-wrap: balance;"
        >
          12 años transformando marcas con <strong class="text-primary font-semibold">Diseño Web Premium</strong>,
          <strong class="text-primary font-semibold">Marketing Estratégico</strong> e
          <strong class="text-primary font-semibold">Identidad Visual</strong>
          en Córdoba y el mundo.
        </p>

        <!-- CTAs -->
        <div data-reveal="up" data-reveal-delay="0.2" class="flex flex-col sm:flex-row gap-4">
          <Button variant="primary" size="lg" href="#servicios">
            Conocer servicios
          </Button>
          <Button variant="secondary" size="lg" href="#contacto">
            Solicitar presupuesto
          </Button>
        </div>

        <!-- Scroll cue -->
        <div
          data-reveal="up"
          data-reveal-delay="0.35"
          class="mt-20 flex items-center gap-3 text-muted text-xs font-mono"
        >
          <div id="scroll-indicator" class="flex flex-col gap-1 items-center">
            <div class="w-px h-8 bg-gradient-to-b from-transparent to-brand-primary opacity-60 animate-pulse" />
          </div>
          Scroll para explorar
        </div>
      </div>
    </div>

    <!-- Bottom fade to next section -->
    <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, var(--color-surface-bg));"
    />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §2  TRUST TICKER
  ══════════════════════════════════════════════════════════ -->
  <section class="py-16 border-y border-surface relative overflow-hidden" aria-label="Clientes">
    <!-- Muted bg -->
    <div aria-hidden="true" class="absolute inset-0"
      style="background: linear-gradient(180deg, var(--color-surface-bg), var(--color-surface-overlay) 50%, var(--color-surface-bg));"
    />
    <TrustTicker
      eyebrow="Empresas que confían en TradeWeb"
      speed={40}
      class="relative z-base"
    />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §3  SERVICES BENTO GRID
  ══════════════════════════════════════════════════════════ -->
  <section
    id="servicios"
    class="py-24 md:py-36 relative"
    aria-labelledby="services-heading"
  >
    <div class="container-site">
      <!-- Section header -->
      <div class="grid lg:grid-cols-2 gap-8 mb-16 items-end">
        <div>
          <div data-reveal="up" class="mb-4">
            <span class="section-eyebrow">Servicios</span>
          </div>
          <h2
            id="services-heading"
            data-reveal="up"
            data-reveal-delay="0.08"
            class="font-display font-extrabold text-primary"
            style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          >
            Todo lo que tu<br/>marca digital necesita.
          </h2>
        </div>
        <div data-reveal="up" data-reveal-delay="0.12" class="max-w-sm lg:ml-auto">
          <p class="text-secondary leading-relaxed mb-6">
            Integramos diseño, tecnología y estrategia de marketing para que cada
            proyecto sea una inversión con retorno medible.
          </p>
          <a href="#contacto" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:gap-4 transition-all duration-fast">
            Hablar con un especialista
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      </div>

      <!-- Bento grid -->
      <div
        data-reveal-group
        class="grid grid-cols-1 md:grid-cols-3 gap-4"
      >
        {services.map((s) => (
          <div data-reveal-item class={s.bento ?? 'col-span-1'}>
            <ServiceCard
              id={s.id}
              title={s.title}
              description={s.description}
              icon={s.icon}
              tag={s.tag}
              stat={s.stat}
              href={s.href}
              ctaText={s.ctaText}
              accent={s.accent}
              class="h-full"
            />
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §4  PORTFOLIO — HORIZONTAL GSAP SCROLL
  ══════════════════════════════════════════════════════════ -->
  <section
    id="portfolio"
    class="relative overflow-hidden"
    aria-labelledby="portfolio-heading"
    style="background: var(--color-surface-overlay);"
  >
    <div class="container-site pt-24 pb-10">
      <div class="flex items-end justify-between gap-8 flex-wrap mb-16">
        <div>
          <div data-reveal="up" class="mb-4">
            <span class="section-eyebrow">Portfolio</span>
          </div>
          <h2
            id="portfolio-heading"
            data-reveal="up"
            data-reveal-delay="0.08"
            class="font-display font-extrabold text-primary"
            style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          >
            Trabajo que<br/>habla por sí solo.
          </h2>
        </div>
        <div data-reveal="left" data-reveal-delay="0.1">
          <a
            href="/portfolio"
            class="inline-flex items-center gap-2 text-sm font-semibold text-secondary hover:text-primary transition-colors duration-fast"
          >
            Ver todos los proyectos
            <Icon name="arrow-up-right" size={14} />
          </a>
        </div>
      </div>
    </div>

    <!-- Horizontal scroll container — GSAP pin -->
    <div
      id="portfolio-pin-wrapper"
      class="relative"
      style="height: 280vh;"
      aria-label="Proyectos destacados"
    >
      <div
        id="portfolio-pin-inner"
        class="sticky top-0 h-screen flex items-center overflow-hidden"
      >
        <!-- Track — animated by GSAP via ScrollTrigger -->
        <div
          id="portfolio-track"
          class="flex gap-6 will-change-transform"
          style="padding: 0 max(24px, calc((100vw - 1320px)/2 + 64px));"
        >
          {portfolio.map((p) => (
            <article
              class="portfolio-card group relative flex-shrink-0 rounded-2xl overflow-hidden cursor-pointer"
              style={`width: min(480px, 80vw); height: 70vh; background: ${p.bg}; border: 1px solid ${p.accent}18;`}
              aria-label={`${p.title} — ${p.category}`}
              tabindex="0"
            >
              <!-- Top glow strip -->
              <div
                aria-hidden="true"
                class="absolute top-0 left-0 right-0 h-px"
                style={`background: linear-gradient(90deg, transparent, ${p.accent}70, transparent);`}
              />

              <!-- Reveal overlay -->
              <div
                aria-hidden="true"
                class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-slow"
                style={`background: linear-gradient(135deg, ${p.accent}12 0%, transparent 60%);`}
              />

              <!-- Content -->
              <div class="absolute inset-0 p-8 md:p-10 flex flex-col justify-between">
                <div class="flex items-start justify-between">
                  <span
                    class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-mono tracking-widest uppercase"
                    style={`background: ${p.accent}14; color: ${p.accent}; border: 1px solid ${p.accent}25;`}
                  >
                    {p.category}
                  </span>
                  <span class="text-muted text-xs font-mono">{p.year}</span>
                </div>

                <!-- Wireframe mockup center -->
                <div aria-hidden="true" class="flex-1 flex items-center justify-center py-12">
                  <div class="w-full max-w-xs space-y-3">
                    <div class="h-2 rounded-full w-3/4 mx-auto" style={`background: ${p.accent}30;`} />
                    <div class="h-8 rounded-lg w-full" style="background: rgba(255,255,255,0.05);" />
                    <div class="h-8 rounded-lg w-4/5" style="background: rgba(255,255,255,0.035);" />
                    <div class="h-4 rounded w-full mt-2" style="background: rgba(255,255,255,0.025);" />
                    <div class="h-4 rounded w-5/6" style="background: rgba(255,255,255,0.02);" />
                    <div class="h-10 rounded-xl w-36 mx-auto mt-4" style={`background: ${p.accent}35;`} />
                  </div>
                </div>

                <div>
                  <h3
                    class="font-display font-bold text-2xl text-primary mb-2"
                    style="letter-spacing: -0.02em;"
                  >
                    {p.title}
                  </h3>
                  <p class="text-secondary text-sm leading-snug mb-4">{p.desc}</p>
                  <span
                    class="inline-flex items-center gap-1.5 text-sm font-semibold transition-all duration-fast group-hover:gap-3"
                    style={`color: ${p.accent};`}
                  >
                    Ver proyecto
                    <Icon name="arrow-right" size={14} />
                  </span>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Progress bar -->
        <div
          class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-3"
          aria-hidden="true"
        >
          <span class="text-muted text-xs font-mono">01</span>
          <div class="w-32 h-px bg-surface-card rounded-full overflow-hidden">
            <div id="portfolio-progress" class="h-full bg-brand-primary rounded-full" style="width: 0%;" />
          </div>
