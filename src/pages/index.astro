<!-- ══════════════════════════════════════════════════════
     GLOBAL PAGE SCRIPTS
══════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── §0 DATA-REVEAL SCROLL ANIMATIONS ──────────────────────────────────────
  if (!prefersReduced) {
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      const dir   = el.dataset.reveal ?? 'up';
      const delay = parseFloat(el.dataset.revealDelay ?? '0');

      gsap.fromTo(el,
        {
          autoAlpha: 0,
          y: dir === 'up'   ?  28 : 0,
          x: dir === 'left' ?  28 : dir === 'right' ? -28 : 0,
        },
        {
          autoAlpha: 1, y: 0, x: 0,
          duration: 0.65,
          delay,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: el,
            start:   'top 90%',
            once:    true,
          },
        }
      );
    });

    document.querySelectorAll<HTMLElement>('[data-reveal-group]').forEach((group) => {
      const items = group.querySelectorAll<HTMLElement>('[data-reveal-item]');
      gsap.fromTo(items,
        { autoAlpha: 0, y: 28 },
        {
          autoAlpha: 1, y: 0,
          duration: 0.55,
          ease: 'power2.out',
          stagger: 0.1,
          scrollTrigger: {
            trigger: group,
            start:   'top 88%',
            once:    true,
          },
        }
      );
    });
  }

  // ── §1 HERO PARALLAX ──────────────────────────────────────────────────────
  const heroGrid  = document.getElementById('hero-grid');
  const heroGlow1 = document.getElementById('hero-glow-1');
  const heroGlow2 = document.getElementById('hero-glow-2');

  if (heroGrid && !prefersReduced) {
    gsap.to(heroGrid, {
      yPercent: 35,
      ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true },
    });
    gsap.to(heroGlow1, {
      yPercent: -25, xPercent: 10,
      ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1.5 },
    });
    gsap.to(heroGlow2, {
      yPercent: 20, xPercent: -10,
      ease: 'none',
      scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1.5 },
    });
  }

  // ── §4 PORTFOLIO HORIZONTAL SCROLL (desktop only) ─────────────────────────
  const pinWrapper  = document.getElementById('portfolio-pin-wrapper');
  const track       = document.getElementById('portfolio-track');
  const progressBar = document.getElementById('portfolio-progress');

  if (pinWrapper && track && window.innerWidth >= 768) {
    const totalWidth = track.scrollWidth - window.innerWidth;

    gsap.to(track, {
      x:    () => -totalWidth,
      ease: 'none',
      scrollTrigger: {
        trigger: pinWrapper,
        start:   'top top',
        end:     () => `+=${pinWrapper.offsetHeight}`,
        scrub:   1,
        pin:     '#portfolio-pin-inner',
        anticipatePin: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          if (progressBar) progressBar.style.width = `${self.progress * 100}%`;
        },
      },
    });
  }

  // ── §5 COUNTER ANIMATION ─────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.counter').forEach((el) => {
    const target   = parseFloat(el.dataset.target ?? '0');
    const decimals = parseInt(el.dataset.decimals ?? '0', 10);
    const suffix   = el.dataset.suffix ?? '';
    const obj      = { val: 0 };

    ScrollTrigger.create({
      trigger: el,
      start:   'top 85%',
      once:    true,
      onEnter: () => {
        if (prefersReduced) {
          el.textContent = target.toFixed(decimals) + suffix;
          return;
        }
        gsap.to(obj, {
          val:      target,
          duration: 1.8,
          ease:     'power2.out',
          onUpdate: () => { el.textContent = obj.val.toFixed(decimals) + suffix; },
        });
      },
    });

    el.textContent = '0' + suffix;
  });

  // ── CONTACT FORM — inline validation ────────────────────────────────────────
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const btnText = document.getElementById('cf-btn-text');
  const success = document.getElementById('cf-success') as HTMLElement | null;

  function validateField(input: HTMLInputElement | HTMLTextAreaElement): boolean {
    const errEl = document.getElementById(`${input.id}-err`);
    const valid = input.checkValidity();
    if (errEl) errEl.classList.toggle('hidden', valid);
    input.setAttribute('aria-invalid', valid ? 'false' : 'true');
    return valid;
  }

  // Live validation on blur
  form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[required], textarea[required]').forEach((el) => {
    el.addEventListener('blur', () => validateField(el));
    el.addEventListener('input', () => {
      if (el.getAttribute('aria-invalid') === 'true') validateField(el);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    let allValid = true;

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[required], textarea[required]').forEach((el) => {
      if (!validateField(el)) allValid = false;
    });

    if (!allValid) return;

    // GSAP-animated submit flow
    const btn       = form.querySelector<HTMLButtonElement>('#cf-submit');
    const spinner   = document.getElementById('cf-btn-spinner');
    const check     = document.getElementById('cf-btn-check');

    if (btn && btnText && spinner && check) {
      btn.disabled = true;

      // Phase 1: text → spinner
      gsap.to(btnText, { opacity: 0, y: -8, duration: 0.25, ease: 'power2.in' });
      gsap.to(spinner, { opacity: 1, duration: 0.3, delay: 0.15, ease: 'power2.out' });

      await new Promise(r => setTimeout(r, 1400));

      // Phase 2: spinner → check
      gsap.to(spinner, { opacity: 0, duration: 0.2, ease: 'power2.in' });
      gsap.to(check,   { opacity: 1, scale: 1, duration: 0.4, delay: 0.1, ease: 'back.out(1.7)' });

      if (success) {
        success.hidden = false;
        form.reset();
      }

      // Phase 3: reset after delay
      await new Promise(r => setTimeout(r, 2000));
      gsap.to(check,   { opacity: 0, duration: 0.2 });
      gsap.to(btnText, { opacity: 1, y: 0, duration: 0.3, delay: 0.15, ease: 'power2.out' });
      btn.disabled = false;
    }
  });
</script>

