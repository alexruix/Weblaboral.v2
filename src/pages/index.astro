---
/**
 * src/pages/index.astro — Agency Homepage
 *
 * Design philosophy: Neo-Minimalista · Modern Tech · Conversion-Focused
 * Reference content: tradeweb.com.ar (content only, redesigned from scratch)
 *
 * Sections:
 *  1. Hero           — Massive type + parallax + CTA shimmer
 *  2. Trust Ticker   — Greyscale → color logo loop (GSAP)
 *  3. Services Bento — Magnetic card hover grid
 *  4. Portfolio Reel — Horizontal GSAP scroll section
 *  5. Stats Bar      — 3 animated counters with ScrollTrigger
 *  6. Testimonials   — Two-column trust grid
 *  7. Contact Form   — Glassmorphism, inline validation
 */

import Layout          from '@layouts/Layout.astro';
import Navbar          from '@organisms/Navbar.astro';
import Footer          from '@organisms/Footer.astro';
import TrustTicker     from '@organisms/TrustTicker.astro';
import Button          from '@atoms/Button.astro';
import Icon            from '@atoms/Icon.astro';
import ServiceCard     from '@molecules/ServiceCard.astro';
import TestimonialCard from '@molecules/TestimonialCard.astro';

import { navLinks, services, portfolio, testimonials, stats, footerColumns } from '@data/site';
---

<Layout
  seo={{
    title: 'TradeWeb — Motores de Venta Digital en Córdoba | Diseño Web, SEO y Marketing',
    description: '12 años transformando marcas con Diseño Web Premium, Marketing Estratégico e Identidad Visual en Córdoba y el mundo. Más de 280 proyectos entregados.',
    ogType: 'website',
    jsonLd: {
      '@type': 'ProfessionalService',
      name: 'TradeWeb',
      description: 'Agencia digital especializada en diseño web, SEO, publicidad digital e identidad visual en Córdoba, Argentina.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Córdoba',
        addressCountry: 'AR',
      },
      url: 'https://tradeweb.com.ar',
      telephone: '+543515000000',
      priceRange: '$$',
      areaServed: ['Argentina', 'Latinoamérica'],
    },
  }}
>
  <Navbar slot="navbar" links={navLinks} currentPath="/" logoText="TradeWeb" />

  <!-- ═══════════════════════════════════════════════════════
       §1  HERO
  ══════════════════════════════════════════════════════════ -->
  <section
    id="hero"
    class="relative min-h-screen flex items-center overflow-hidden"
    aria-label="Hero"
  >
    <!-- GSAP-driven parallax bg elements — animated via script below -->
    <div id="hero-grid" aria-hidden="true"      class="absolute inset-0 noise-overlay pointer-events-none"
      style="background-image: linear-gradient(var(--color-grid-line) 1px, transparent 1px), linear-gradient(90deg, var(--color-grid-line) 1px, transparent 1px); background-size: 72px 72px; opacity: 0.5;"
    />
    <div id="hero-glow-1" aria-hidden="true" class="absolute pointer-events-none will-change-transform"
      style="top: -20%; right: -10%; width: 70vw; height: 70vw; background: radial-gradient(circle, var(--color-glow-primary) 0%, transparent 65%); border-radius: 50%;"
    />
    <div id="hero-glow-2" aria-hidden="true" class="absolute pointer-events-none will-change-transform"
      style="bottom: -10%; left: -15%; width: 60vw; height: 60vw; background: radial-gradient(circle, var(--color-glow-secondary) 0%, transparent 65%); border-radius: 50%;"
    />

    <!-- Scan-line decoration -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="animate-scan-line absolute left-0 right-0 h-px opacity-10"
        style="background: linear-gradient(90deg, transparent, var(--color-brand-primary), transparent);"
      />
    </div>

    <div class="container-site relative z-base w-full pt-28 pb-20">
      <div class="max-w-5xl">

        <!-- Eyebrow -->
        <div data-reveal="up" class="flex items-center gap-3 mb-10">
          <span class="section-eyebrow">
            <span class="relative flex w-2 h-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-60"></span>
              <span class="relative inline-flex rounded-full w-2 h-2 bg-brand-primary"></span>
            </span>
            Córdoba, Argentina · +280 proyectos
          </span>
        </div>

        <!-- Headline — massif -->
        <h1
          id="hero-headline"
          data-reveal="up"
          data-reveal-delay="0.05"
          class="font-display font-extrabold text-primary mb-8"
          style="font-size: clamp(3.5rem, 8vw, 6rem); letter-spacing: -0.04em; line-height: 1.05; text-wrap: balance;"
        >
          No Hacemos Webs.<br/>
          Construimos <span class="text-gradient">Motores de Venta</span>.
        </h1>

        <!-- Subheadline -->
        <p
          data-reveal="up"
          data-reveal-delay="0.12"
          class="text-secondary text-xl leading-relaxed max-w-2xl mb-12"
          style="text-wrap: balance;"
        >
          12 años transformando marcas con <strong class="text-primary font-semibold">Diseño Web Premium</strong>,
          <strong class="text-primary font-semibold">Marketing Estratégico</strong> e
          <strong class="text-primary font-semibold">Identidad Visual</strong>
          en Córdoba y el mundo.
        </p>

        <!-- CTAs -->
        <div data-reveal="up" data-reveal-delay="0.2" class="flex flex-col sm:flex-row gap-4">
          <Button variant="primary" size="lg" href="#contacto">
            Solicitar presupuesto gratis
          </Button>
          <Button variant="secondary" size="lg" href="#servicios">
            Ver nuestros servicios
          </Button>
        </div>

        <!-- Scroll cue -->
        <div
          data-reveal="up"
          data-reveal-delay="0.35"
          class="mt-20 flex items-center gap-3 text-muted text-xs font-mono"
        >
          <div id="scroll-indicator" class="flex flex-col gap-1 items-center">
            <div class="w-px h-8 bg-gradient-to-b from-transparent to-brand-primary opacity-60 animate-pulse" />
          </div>
          Scroll para explorar
        </div>
      </div>
    </div>

    <!-- Bottom fade to next section -->
    <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, var(--color-surface-bg));"
    />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §2  TRUST TICKER
  ══════════════════════════════════════════════════════════ -->
  <section class="py-16 border-y border-surface relative overflow-hidden" aria-label="Clientes">
    <!-- Muted bg -->
    <div aria-hidden="true" class="absolute inset-0"
      style="background: linear-gradient(180deg, var(--color-surface-bg), var(--color-surface-overlay) 50%, var(--color-surface-bg));"
    />
    <TrustTicker
      eyebrow="Empresas que confían en TradeWeb"
      speed={40}
      class="relative z-base"
    />
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §3  SERVICES BENTO GRID
  ══════════════════════════════════════════════════════════ -->
  <section
    id="servicios"
    class="py-24 md:py-36 relative"
    aria-labelledby="services-heading"
  >
    <div class="container-site">
      <!-- Section header -->
      <div class="grid lg:grid-cols-2 gap-8 mb-16 items-end">
        <div>
          <div data-reveal="up" class="mb-4">
            <span class="section-eyebrow">Servicios</span>
          </div>
          <h2
            id="services-heading"
            data-reveal="up"
            data-reveal-delay="0.08"
            class="font-display font-extrabold text-primary"
            style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          >
            Todo lo que tu<br/>marca digital necesita.
          </h2>
        </div>
        <div data-reveal="up" data-reveal-delay="0.12" class="max-w-sm lg:ml-auto">
          <p class="text-secondary leading-relaxed mb-6">
            Integramos diseño, tecnología y estrategia de marketing para que cada
            proyecto sea una inversión con retorno medible.
          </p>
          <a href="#contacto" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:gap-4 transition-all duration-fast">
            Hablar con un especialista
            <Icon name="arrow-right" size={14} />
          </a>
        </div>
      </div>

      <!-- Bento grid with anchor IDs per service category -->
      <div
        data-reveal-group
        class="grid grid-cols-1 md:grid-cols-3 gap-4"
      >
        {services.map((s) => (
          <div id={s.anchorId} data-reveal-item class={s.bento ?? 'col-span-1'}>
            <ServiceCard
              id={s.id}
              title={s.title}
              description={s.description}
              icon={s.icon}
              tag={s.tag}
              stat={s.stat}
              href={s.href}
              ctaText={s.ctaText}
              accent={s.accent}
              class="h-full"
            />
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §4  PORTFOLIO — HORIZONTAL GSAP SCROLL
  ══════════════════════════════════════════════════════════ -->
  <section
    id="portfolio"
    class="relative overflow-hidden"
    aria-labelledby="portfolio-heading"
    style="background: var(--color-surface-overlay);"
  >
    <div class="container-site pt-24 pb-10">
      <div class="flex items-end justify-between gap-8 flex-wrap mb-16">
        <div>
          <div data-reveal="up" class="mb-4">
            <span class="section-eyebrow">Portfolio</span>
          </div>
          <h2
            id="portfolio-heading"
            data-reveal="up"
            data-reveal-delay="0.08"
            class="font-display font-extrabold text-primary"
            style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          >
            Trabajo que<br/>habla por sí solo.
          </h2>
        </div>
        <div data-reveal="left" data-reveal-delay="0.1">
          <a
            href="/portfolio"
            class="inline-flex items-center gap-2 text-sm font-semibold text-secondary hover:text-primary transition-colors duration-fast"
          >
            Ver todos los proyectos
            <Icon name="arrow-up-right" size={14} />
          </a>
        </div>
      </div>
    </div>

    <!-- Horizontal scroll container — GSAP pin -->
    <div
      id="portfolio-pin-wrapper"
      class="relative"
      style="height: 280vh;"
      aria-label="Proyectos destacados"
    >
      <div
        id="portfolio-pin-inner"
        class="sticky top-0 h-screen flex items-center overflow-hidden"
      >
        <!-- Track — animated by GSAP via ScrollTrigger -->
        <div
          id="portfolio-track"
          class="flex gap-6 will-change-transform"
          style="padding: 0 max(24px, calc((100vw - 1320px)/2 + 64px));"
        >
          {portfolio.map((p) => (
            <article
              class="portfolio-card group relative flex-shrink-0 rounded-2xl overflow-hidden"
              style={`width: min(480px, 80vw); height: 70vh; background: ${p.bg}; border: 1px solid ${p.accent}18;`}
              aria-label={`${p.title} — ${p.category}`}
            >
              <!-- Top glow strip -->
              <div
                aria-hidden="true"
                class="absolute top-0 left-0 right-0 h-px"
                style={`background: linear-gradient(90deg, transparent, ${p.accent}70, transparent);`}
              />

              <!-- Reveal overlay -->
              <div
                aria-hidden="true"
                class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-slow"
                style={`background: linear-gradient(135deg, ${p.accent}12 0%, transparent 60%);`}
              />

              <!-- A11y: real link wraps entire content -->
              <a
                href={`/portfolio/${p.id}`}
                class="absolute inset-0 p-8 md:p-10 flex flex-col justify-between focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
                style={`--tw-ring-color: ${p.accent};`}
                aria-label={`Ver proyecto: ${p.title}`}
              >
                <div class="flex items-start justify-between">
                  <span
                    class="inline-flex items-center px-3 py-1 rounded-full text-[11px] tracking-widest uppercase font-medium"
                    style={`background: ${p.accent}14; color: ${p.accent}; border: 1px solid ${p.accent}25;`}
                  >
                    {p.category}
                  </span>
                  <span class="text-muted text-xs" style="font-family: 'JetBrains Mono', monospace;">{p.year}</span>
                </div>

                <!-- Wireframe mockup center -->
                <div aria-hidden="true" class="flex-1 flex items-center justify-center py-12">
                  <div class="w-full max-w-xs space-y-3">
                    <div class="h-2 rounded-full w-3/4 mx-auto" style={`background: ${p.accent}30;`} />
                    <div class="h-8 rounded-lg w-full" style="background: var(--color-surface-border);" />
                    <div class="h-8 rounded-lg w-4/5" style="background: var(--color-surface-border);" />
                    <div class="h-4 rounded w-full mt-2" style="background: var(--color-surface-border);" />
                    <div class="h-4 rounded w-5/6" style="background: var(--color-surface-border);" />
                    <div class="h-10 rounded-xl w-36 mx-auto mt-4" style={`background: ${p.accent}35;`} />
                  </div>
                </div>

                <div>
                  <h3
                    class="font-display font-bold text-2xl text-primary mb-2"
                    style="letter-spacing: -0.02em;"
                  >
                    {p.title}
                  </h3>
                  <p class="text-secondary text-sm leading-snug mb-4">{p.desc}</p>
                  <span
                    class="inline-flex items-center gap-1.5 text-sm font-semibold"
                    style={`color: ${p.accent};`}
                  >
                    Ver proyecto
                    <Icon name="arrow-right" size={14} />
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>

        <!-- Progress bar -->
        <div
          class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-3"
          aria-hidden="true"
        >
          <span class="text-muted text-xs font-mono">01</span>
          <div class="w-32 h-px bg-surface-card rounded-full overflow-hidden">
            <div id="portfolio-progress" class="h-full bg-brand-primary rounded-full" style="width: 0%;" />
          </div>
          <span class="text-muted text-xs font-mono">0{portfolio.length}</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §5  STATS BAR
  ══════════════════════════════════════════════════════════ -->
  <section
    id="la-agencia"
    class="py-20 border-y border-surface relative overflow-hidden"
    aria-labelledby="stats-heading"
  >
    <h2 id="stats-heading" class="sr-only">La Agencia en números</h2>
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 80% 100% at 50% 50%, var(--color-glow-primary) 0%, transparent 70%);"
    />
    <div class="container-site relative z-base">
      <div
        data-reveal-group
        class="grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 divide-x-0 lg:divide-x divide-surface"
      >
        {stats.map((s, i) => (
          <div
            data-reveal-item
            class:list={['text-center lg:text-left', i > 0 ? 'lg:pl-8' : '']}
          >
            <p
              class="counter font-display font-extrabold mb-1"
              style={`font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em; color: ${s.accent};`}
              data-target={s.value}
              data-decimals={s.decimals ?? 0}
              data-suffix={s.suffix ?? ''}
            >
              {s.value}{s.suffix}
            </p>
            <p class="text-secondary text-sm font-mono leading-snug">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §6  TESTIMONIALS
  ══════════════════════════════════════════════════════════ -->
  <section
    id="testimonios"
    class="py-24 md:py-36 relative overflow-hidden"
    aria-labelledby="testimonials-heading"
  >
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 60% 50% at 100% 50%, var(--color-glow-primary) 0%, transparent 60%);"
    />
    <div class="container-site relative z-base">
      <div class="text-center mb-16">
        <div data-reveal="up" class="flex justify-center mb-4">
          <span class="section-eyebrow">Testimonios</span>
        </div>
        <h2
          id="testimonials-heading"
          data-reveal="up"
          data-reveal-delay="0.08"
          class="font-display font-extrabold text-primary max-w-xl mx-auto"
          style="font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; line-height: 1.05;"
        >
          Lo que dicen quienes<br/>ya dieron el salto.
        </h2>
      </div>

      <!-- Featured (2 col) -->
      <div data-reveal-group class="grid md:grid-cols-2 gap-6 mb-6">
        {testimonials.filter(t => t.featured).map(t => (
          <div data-reveal-item>
            <TestimonialCard {...t} />
          </div>
        ))}
      </div>

      <!-- Standard (2 col) -->
      <div data-reveal-group class="grid md:grid-cols-2 gap-6">
        {testimonials.filter(t => !t.featured).map(t => (
          <div data-reveal-item>
            <TestimonialCard {...t} />
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §7  CONTACT FORM — GLASSMORPHISM
  ══════════════════════════════════════════════════════════ -->
  <section
    id="contacto"
    class="py-24 md:py-36 relative overflow-hidden"
    aria-labelledby="contact-heading"
    style="background: var(--color-surface-overlay);"
  >
    <!-- Decorative radials -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 60% 80% at 0% 100%, var(--color-glow-primary) 0%, transparent 50%), radial-gradient(ellipse 40% 60% at 100% 0%, var(--color-glow-secondary) 0%, transparent 50%);"
    />

    <div class="container-site relative z-base">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <!-- Left: copy -->
        <div class="lg:sticky lg:top-24">
          <div data-reveal="up" class="mb-5">
            <span class="section-eyebrow">Contacto</span>
          </div>
          <h2
            id="contact-heading"
            data-reveal="up"
            data-reveal-delay="0.08"
            class="font-display font-extrabold text-primary mb-6"
            style="font-size: clamp(2rem, 4.5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05;"
          >
            Empezá hoy.<br/>
            <span class="text-brand-primary">Te respondemos</span><br/>
            en menos de 24hs.
          </h2>
          <p class="text-secondary leading-relaxed mb-10" data-reveal="up" data-reveal-delay="0.12">
            Contanos sobre tu proyecto y un especialista te preparará
            una propuesta personalizada sin costo.
          </p>

          <!-- Contact quick links -->
          <ul class="space-y-4" data-reveal="up" data-reveal-delay="0.16">
            {[
              { icon: 'whatsapp' as const, label: '+54 9 351 500-0000', href: 'https://wa.me/5493515000000', color: '#22D35A' },
              { icon: 'mail'     as const, label: 'hola@tradeweb.com.ar', href: 'mailto:hola@tradeweb.com.ar', color: '#0CF2D0' },
              { icon: 'map-pin'  as const, label: 'Córdoba, Argentina', href: 'https://maps.google.com/?q=Córdoba,+Argentina', color: '#1B6FFF' },
            ].map(item => (
              <li>
                <a
                  href={item.href}
                  class="flex items-center gap-3 text-secondary hover:text-primary transition-colors duration-fast group"
                >
                  <span
                    class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 transition-transform duration-fast group-hover:scale-110"
                    style={`background: ${item.color}14; color: ${item.color};`}
                  >
                    <Icon name={item.icon} size={16} />
                  </span>
                  <span class="text-sm">{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: Glassmorphism form -->
        <div data-reveal="up" data-reveal-delay="0.1">
          <form
            id="contact-form"
            novalidate
            aria-label="Formulario de contacto"
            class="glass rounded-2xl p-8 md:p-10 space-y-6"
            style="border-color: var(--color-brand-primary);"
          >
            <!-- Name + Email row -->
            <div class="grid sm:grid-cols-2 gap-6">
              <div class="form-field-wrap">
                <label for="cf-name" class="form-label">
                  Nombre <span aria-hidden="true" class="text-semantic-error">*</span>
                </label>
                <input
                  type="text"
                  id="cf-name"
                  name="nombre"
                  autocomplete="given-name"
                  required
                  minlength="2"
                  placeholder="Tu nombre"
                  class="form-input"
                  aria-required="true"
                  aria-describedby="cf-name-err"
                />
                <span id="cf-name-err" role="alert" class="form-error hidden">
                  Ingresá tu nombre
                </span>
              </div>

              <div class="form-field-wrap">
                <label for="cf-email" class="form-label">
                  Email <span aria-hidden="true" class="text-semantic-error">*</span>
                </label>
                <input
                  type="email"
                  id="cf-email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="tu@email.com"
                  class="form-input"
                  aria-required="true"
                  aria-describedby="cf-email-err"
                />
                <span id="cf-email-err" role="alert" class="form-error hidden">
                  Ingresá un email válido
                </span>
              </div>
            </div>

            <!-- Service select -->
            <div class="form-field-wrap">
              <label for="cf-service" class="form-label">¿Qué servicio necesitás?</label>
              <select id="cf-service" name="servicio" class="form-input" style="appearance: none;">
                <option value="">Seleccioná un servicio</option>
                <option value="landing">Landing Page</option>
                <option value="ecommerce">E-Commerce</option>
                <option value="hotel">Sitio para Hotel</option>
                <option value="seo">SEO Estratégico</option>
                <option value="ads">Google & Meta Ads</option>
                <option value="branding">Identidad Visual</option>
                <option value="otro">Otro / No sé aún</option>
              </select>
            </div>

            <!-- Budget range -->
            <div class="form-field-wrap">
              <label for="cf-budget" class="form-label">Presupuesto estimado</label>
              <select id="cf-budget" name="presupuesto" class="form-input" style="appearance: none;">
                <option value="">Seleccioná un rango</option>
                <option value="lt30">Hasta $30.000 ARS</option>
                <option value="30-80">$30.000 – $80.000 ARS</option>
                <option value="80-200">$80.000 – $200.000 ARS</option>
                <option value="gt200">Más de $200.000 ARS</option>
                <option value="usd">Presupuesto en USD</option>
              </select>
            </div>

            <!-- Message -->
            <div class="form-field-wrap">
              <label for="cf-message" class="form-label">
                Contanos sobre tu proyecto <span aria-hidden="true" class="text-semantic-error">*</span>
              </label>
              <textarea
                id="cf-message"
                name="mensaje"
                required
                minlength="20"
                rows="4"
                placeholder="¿Qué necesitás? ¿Tenés fecha límite? ¿Algún referente de diseño?"
                class="form-input resize-none"
                aria-required="true"
                aria-describedby="cf-message-err"
              ></textarea>
              <span id="cf-message-err" role="alert" class="form-error hidden">
