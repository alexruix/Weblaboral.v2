    pointer-events: none;
  }

  #cf-submit:not(:disabled):hover .btn-shimmer {
    transform: translateX(120%);
  }

  /* ── P1 Audit Fix: Portfolio mobile fallback ──────────────────────────────
   * On mobile the GSAP pin is disabled; cards render as a 2-col grid instead.
   * The pin-wrapper height collapses to auto on mobile via the .portfolio-mobile class.
   */
  @media (max-width: 767px) {
    #portfolio-pin-wrapper {
      height: auto !important;
    }
    #portfolio-pin-inner {
      position: static !important;
      height: auto !important;
      overflow: visible !important;
      padding-bottom: 2rem;
    }
    #portfolio-track {
      flex-wrap: wrap;
      transform: none !important;          /* override GSAP translateX */
      width: auto !important;
      padding: 0 1rem;
      gap: 1rem;
      justify-content: center;
    }
    .portfolio-card {
      width: calc(50% - 0.5rem) !important;
      height: 320px !important;
      min-width: 140px;
    }
    #portfolio-progress {
      display: none;
    }
    #portfolio-hint-desktop {
      display: none;
    }
  }

  /* ── P2: sr-only helper if not already in Tailwind output ─────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>