<!-- ══════════════════════════════════════════════════════
     GLOBAL PAGE SCRIPTS
══════════════════════════════════════════════════════ -->
<script>
  // ── Wait for GSAP/ScrollTrigger
  function waitFor(fn: () => void, tries = 0) {
    if (typeof window.gsap !== 'undefined' && typeof window.ScrollTrigger !== 'undefined') {
      fn();
    } else if (tries < 80) {
      setTimeout(() => waitFor(fn, tries + 1), 100);
    }
  }

  waitFor(() => {
    const { gsap, ScrollTrigger } = window;
    gsap.registerPlugin(ScrollTrigger);

    // ── §1 HERO PARALLAX ──────────────────────────────────────────────────────
    const heroGrid  = document.getElementById('hero-grid');
    const heroGlow1 = document.getElementById('hero-glow-1');
    const heroGlow2 = document.getElementById('hero-glow-2');

    if (heroGrid && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      gsap.to(heroGrid, {
        yPercent: 35,
        ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to(heroGlow1, {
        yPercent: -25, xPercent: 10,
        ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1.5 },
      });
      gsap.to(heroGlow2, {
        yPercent: 20, xPercent: -10,
        ease: 'none',
        scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1.5 },
      });
    }

    // ── §4 PORTFOLIO HORIZONTAL SCROLL ────────────────────────────────────────
    const pinWrapper = document.getElementById('portfolio-pin-wrapper');
    const track      = document.getElementById('portfolio-track');
    const progressBar = document.getElementById('portfolio-progress');

    if (pinWrapper && track) {
      // Cards + gaps total width minus one viewport
      const totalWidth = track.scrollWidth - window.innerWidth;

      gsap.to(track, {
        x:    () => -totalWidth,
        ease: 'none',
        scrollTrigger: {
          trigger: pinWrapper,
          start:   'top top',
          end:     () => `+=${pinWrapper.offsetHeight}`,
          scrub:   1,
          pin:     '#portfolio-pin-inner',
          anticipatePin: 1,
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            if (progressBar) progressBar.style.width = `${self.progress * 100}%`;
          },
        },
      });

      // Keyboard navigation for portfolio cards
      document.querySelectorAll<HTMLElement>('.portfolio-card').forEach((card) => {
        card.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            const link = card.querySelector('a');
            if (link) link.click();
          }
        });
      });
    }

    // ── §5 COUNTER ANIMATION ─────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.counter').forEach((el) => {
      const target   = parseFloat(el.dataset.target ?? '0');
      const decimals = parseInt(el.dataset.decimals ?? '0', 10);
      const suffix   = el.dataset.suffix ?? '';
      const obj      = { val: 0 };

      ScrollTrigger.create({
        trigger: el,
        start:   'top 85%',
        once:    true,
        onEnter: () => {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            el.textContent = target.toFixed(decimals) + suffix;
            return;
          }
          gsap.to(obj, {
            val:      target,
            duration: 1.8,
            ease:     'power2.out',
            onUpdate: () => { el.textContent = obj.val.toFixed(decimals) + suffix; },
          });
        },
      });

      // Init text
      el.textContent = '0' + suffix;
    });
  });

  // ── CONTACT FORM — inline validation ────────────────────────────────────────
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const btnText = document.getElementById('cf-btn-text');
  const success = document.getElementById('cf-success') as HTMLElement | null;

  function validateField(input: HTMLInputElement | HTMLTextAreaElement): boolean {
    const errEl = document.getElementById(`${input.id}-err`);
    const valid = input.checkValidity();
    if (errEl) errEl.classList.toggle('hidden', valid);
    input.setAttribute('aria-invalid', valid ? 'false' : 'true');
    return valid;
  }

  // Live validation on blur
  form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[required], textarea[required]').forEach((el) => {
    el.addEventListener('blur', () => validateField(el));
    el.addEventListener('input', () => {
      if (el.getAttribute('aria-invalid') === 'true') validateField(el);
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    let allValid = true;

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[required], textarea[required]').forEach((el) => {
      if (!validateField(el)) allValid = false;
    });

    if (!allValid) return;

    // Simulate async submit
    const btn = form.querySelector<HTMLButtonElement>('#cf-submit');
    if (btn && btnText) {
      btn.disabled = true;
      btnText.textContent = 'Enviando…';
    }

    await new Promise(r => setTimeout(r, 1400));

    if (success) {
      success.hidden = false;
      form.reset();
    }
    if (btn && btnText) {
      btn.disabled = false;
      btnText.textContent = 'Enviar solicitud';
    }
  });
</script>

