<!-- ════════════════════════════════════════════════════════
     PORTFOLIO CAROUSEL — GSAP
════════════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  /**
   * Portfolio Carousel
   * Uses GSAP to create a smooth auto-scrolling carousel.
   */
  (function initCarousel() {

      const track    = document.getElementById('portfolio-track') as HTMLElement | null;
      const carousel = document.getElementById('portfolio-carousel') as HTMLElement | null;
      if (!track || !carousel) return;

      // Respect reduced motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const cards        = Array.from(track.querySelectorAll('.portfolio-card')) as HTMLElement[];
      const totalCards   = cards.length / 2; // half are duplicates
      const cardWidth    = 320;
      const gap          = 20;
      const singleSetWidth = (cardWidth + gap) * totalCards;

      // ── Auto-scroll animation (infinite loop via modular arithmetic)
      const autoTween = gsap.to(track, {
        x:          () => -singleSetWidth,
        duration:   25,
        ease:       'none',
        repeat:     -1,
        modifiers: {
          x: gsap.utils.unitize((x: string) => parseFloat(x) % singleSetWidth),
        },
      });

      // ── Pause on hover / focus
      carousel.addEventListener('mouseenter', () => autoTween.pause());
      carousel.addEventListener('mouseleave', () => autoTween.resume());
      carousel.addEventListener('focusin',    () => autoTween.pause());
      carousel.addEventListener('focusout',   () => autoTween.resume());

      // ── Drag to scroll
      let isDragging    = false;
      let startX        = 0;
      let startScrollX  = 0;
      let currentX      = 0;
      let velocity      = 0;
      let lastX         = 0;
      let lastTimestamp = 0;
      let rafId: number | null = null;

      const onDown = (e: MouseEvent | TouchEvent) => {
        isDragging   = true;
        startX       = e instanceof MouseEvent ? e.clientX : e.touches[0]!.clientX;
        lastX        = startX;
        lastTimestamp = Date.now();
        startScrollX = gsap.getProperty(track, 'x') as number;
        autoTween.pause();
        track.style.cursor = 'grabbing';
        if (rafId) cancelAnimationFrame(rafId);
      };

      const onMove = (e: MouseEvent | TouchEvent) => {
        if (!isDragging) return;
        const clientX = e instanceof MouseEvent ? e.clientX : e.touches[0]!.clientX;
        const now     = Date.now();
        velocity      = (clientX - lastX) / (now - lastTimestamp || 1);
        lastX         = clientX;
        lastTimestamp = now;

        const dx = clientX - startX;
        currentX = startScrollX + dx;
        gsap.set(track, { x: currentX });
      };

      const onUp = () => {
        if (!isDragging) return;
        isDragging         = false;
        track.style.cursor = 'grab';

        // Momentum scroll
        const momentumTarget = currentX + velocity * 400;
        gsap.to(track, {
          x:        momentumTarget,
          duration: 0.8,
          ease:     'power3.out',
          onComplete: () => { autoTween.resume(); },
        });
      };

      track.style.cursor = 'grab';
      track.addEventListener('mousedown',  onDown as EventListener);
      track.addEventListener('touchstart', onDown as EventListener, { passive: true });
      window.addEventListener('mousemove', onMove as EventListener);
      window.addEventListener('touchmove', onMove as EventListener, { passive: true });
      window.addEventListener('mouseup',   onUp);
      window.addEventListener('touchend',  onUp);

      // ── Card hover effect (lift + glow)
      cards.forEach((card) => {
        card.addEventListener('mouseenter', () => {
          gsap.to(card, { y: -8, scale: 1.02, duration: 0.4, ease: 'power2.out' });
        });
        card.addEventListener('mouseleave', () => {
          gsap.to(card, { y: 0,  scale: 1.00, duration: 0.4, ease: 'power2.inOut' });
        });
      });
  })();
</script>

