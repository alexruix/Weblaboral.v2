---
/**
 * BentoGrid.astro — Organism
 *
 * Reusable Bento Grid component for showcasing services or features.
 * Features: Swiss Minimalism aesthetics, balanced typography,
 * optimal whitespace, responsive density, and GSAP stagger animations.
 */
import Icon from "@atoms/Icon.astro";
import ServiceCard from "@molecules/ServiceCard.astro";

export interface BentoItem {
  id: string;
  anchorId?: string;
  title: string;
  description: string;
  icon: string;
  tag?: string;
  stat?: { value: string; label: string };
  href?: string;
  ctaText?: string;
  accent: string;
  bento?: string; // Ej: 'col-span-1 md:col-span-2 row-span-2'
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  items: BentoItem[];
  id?: string;
}

const {
  id = "bento-grid",
  eyebrow,
  title,
  description,
  ctaLabel,
  ctaHref,
  items,
} = Astro.props;
---

<section
  id={id}
  class="py-24 md:py-36 relative"
  aria-labelledby={`${id}-heading`}
>
  <div class="container-site z-10 relative">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 mb-16 lg:mb-24 items-end">
      <div class="lg:col-span-7">
        {
          eyebrow && (
            <div data-reveal="up" class="mb-5">
              <span class="section-eyebrow">{eyebrow}</span>
            </div>
          )
        }
        <h2
          id={`${id}-heading`}
          data-reveal="up"
          data-reveal-delay="0.08"
          class="font-display font-extrabold text-text-primary"
          style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.03em; line-height: 1.05; text-wrap: balance;"
          set:html={title}
        />
      </div>

      {
        description && (
          <div
            data-reveal="up"
            data-reveal-delay="0.12"
            class="lg:col-span-5 lg:ml-auto max-w-lg lg:pb-3"
          >
            <p
              class="text-text-secondary text-lg leading-relaxed mb-8"
              style="text-wrap: pretty;"
            >
              {description}
            </p>
            {ctaLabel && ctaHref && (
              <a
                href={ctaHref}
                class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary hover:gap-4 transition-all duration-300 ease-out"
              >
                {ctaLabel}
                <Icon name="arrow-right" size={16} />
              </a>
            )}
          </div>
        )
      }
    </div>

    <div
      data-reveal-group
      class="grid grid-cols-1 md:grid-cols-3 md:grid-flow-dense gap-5 md:gap-6 auto-rows-[minmax(280px,auto)] relative"
    >
      <div
        class="absolute inset-x-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[80%] h-[80%] bg-brand-primary/5 blur-[120px] rounded-full pointer-events-none"
        aria-hidden="true"
      >
      </div>

      {
        items.map((item) => (
          <div
            id={item.anchorId}
            data-reveal-item
            class:list={[
              item.bento || "col-span-1 md:col-span-1",
              "group/bento relative flex flex-col w-full h-full",
            ]}
          >
            <ServiceCard
              id={item.id}
              title={item.title}
              description={item.description}
              icon={item.icon}
              tag={item.tag}
              stat={item.stat}
              href={item.href}
              ctaText={item.ctaText}
              accent={item.accent}
              class="h-full flex-1 w-full"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
