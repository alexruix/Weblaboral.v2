---
/**
 * ContactHub.astro — Organism
 * High-conversion contact section. Features sticky intro,
 * GSAP staggered form fields, and Magnetic CTA.
 */
import Input from "@atoms/Input.astro";
import Textarea from "@atoms/Textarea.astro";
import Select from "@atoms/Select.astro";
import Icon from "@atoms/Icon.astro";
import { contactData } from "@data/contact";
---

<section
  id="contacto"
  class="py-24 md:py-36 relative overflow-visible"
  aria-labelledby="contact-heading"
  style="background: var(--color-surface-overlay);"
>
  <!-- Decorative radials -->
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 80% at 0% 100%, var(--color-glow-primary) 0%, transparent 50%), radial-gradient(ellipse 40% 60% at 100% 0%, var(--color-glow-secondary) 0%, transparent 50%); opacity: 0.6;"
  >
  </div>

  <div class="container-site relative z-base">
    <!-- Grid Estructural 50/50 -->
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      <!-- Columna Izquierda: Sticky Info -->
      <div class="lg:sticky lg:top-32 relative z-20">
        <div data-reveal="up" class="mb-5">
          <span class="section-eyebrow">{contactData.eyebrow}</span>
        </div>
        <h2
          id="contact-heading"
          data-reveal="up"
          data-reveal-delay="0.08"
          class="font-display font-extrabold text-text-primary mb-6"
          style="font-size: clamp(2.5rem, 5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1.05; text-wrap: balance;"
          set:html={contactData.heading}
        />
        <p
          class="text-text-secondary text-lg leading-relaxed mb-10 text-pretty"
          data-reveal="up"
          data-reveal-delay="0.12"
        >
          {contactData.description}
        </p>

        <!-- Contact Links -->
        <ul class="space-y-5" data-reveal="up" data-reveal-delay="0.2">
          {
            contactData.links.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="flex items-center gap-4 text-text-secondary hover:text-text-primary transition-colors duration-300 group"
                >
                  <span
                    class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 transition-transform duration-500 ease-spring group-hover:scale-110 group-hover:shadow-lg"
                    style={`background: ${item.color}14; color: ${item.color}; border: 1px solid ${item.color}20;`}
                  >
                    <Icon name={item.icon} size={20} />
                  </span>
                  <span class="text-base font-medium">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna Derecha: Formulario High-Fi -->
      <div class="relative" data-reveal="up" data-reveal-delay="0.1">
        <!-- Mesh Background Tracked by Mouse -->
        <div
          id="form-spotlight"
          class="absolute -inset-4 opacity-0 pointer-events-none transition-opacity duration-1000 z-0 rounded-3xl"
          style="background: radial-gradient(800px circle at var(--fx, 50%) var(--fy, 50%), rgba(12, 242, 208, 0.08), transparent 40%);"
        >
        </div>

        <form
          id="contact-form"
          novalidate
          aria-label="Formulario de contacto"
          class="relative z-10 glass rounded-3xl p-8 sm:p-10 md:p-12 space-y-6 bg-surface-card/40 backdrop-blur-xl border border-white/10 shadow-2xl overflow-hidden"
        >
          <!-- GSAP Stagger Wrapper -->
          <div class="form-fields flex flex-col gap-6">
            <div class="grid sm:grid-cols-2 gap-6">
              <Input
                id="cf-name"
                name="nombre"
                label={contactData.form.nameLabel}
                placeholder={contactData.form.namePlaceholder}
                required
              />
              <Input
                id="cf-email"
                name="email"
                type="email"
                label={contactData.form.emailLabel}
                placeholder={contactData.form.emailPlaceholder}
                required
              />
            </div>

            <Select
              id="cf-service"
              name="servicio"
              label={contactData.form.serviceLabel}
              options={contactData.form.serviceOptions}
            />
            <Select
              id="cf-budget"
              name="presupuesto"
              label={contactData.form.budgetLabel}
              options={contactData.form.budgetOptions}
            />

            <Textarea
              id="cf-message"
              name="mensaje"
              label={contactData.form.messageLabel}
              placeholder={contactData.form.messagePlaceholder}
              required
              rows={5}
            />

            <!-- CTA Magnetic Button -->
            <button
              type="submit"
              id="magnetic-btn"
              class="relative w-full h-16 rounded-xl bg-brand-primary text-[#0A0C18] font-display font-bold tracking-wide mt-4 overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-brand-primary transition-colors hover:bg-[#0AEAD5]"
              aria-label={contactData.form.cta}
            >
              <div
                class="magnetic-inner pointer-events-none flex items-center justify-center gap-3 w-full h-full"
              >
                <span>{contactData.form.cta}</span>
                <Icon name="arrow-up-right" size={20} />
              </div>
            </button>
          </div>

          <!-- Footer del Formulario -->
          <div class="pt-6 mt-6 border-t border-white/10">
            <p class="text-center text-text-muted text-xs mb-3">
              {contactData.form.privacyPrefix}
              <a
                href="/privacidad"
                class="underline hover:text-text-secondary transition-colors"
                >{contactData.form.privacyLinkText}</a
              >.
            </p>
            <p
              class="text-center text-xs font-mono text-text-muted tracking-wide flex items-center justify-center gap-2"
            >
              <span class="relative flex w-2 h-2 shrink-0">
                <span
                  class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-60"
                ></span>
                <span
                  class="relative inline-flex rounded-full w-2 h-2 bg-brand-primary"
                ></span>
              </span>
              {contactData.urgencyPing}
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  const initContactHub = () => {
    // 1. Mesh Gradient Track
    const formContainer = document.querySelector(
      ".lg\\:col-span-7",
    ) as HTMLElement;
    const spotlight = document.getElementById("form-spotlight");

    if (
      formContainer &&
      spotlight &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      formContainer.addEventListener("mousemove", (e) => {
        const rect = formContainer.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        spotlight.style.setProperty("--fx", `${x}px`);
        spotlight.style.setProperty("--fy", `${y}px`);
        gsap.to(spotlight, { opacity: 1, duration: 0.3 });
      });

      formContainer.addEventListener("mouseleave", () => {
        gsap.to(spotlight, { opacity: 0, duration: 1 });
      });
    }

    // 2. Form Fields Stagger Reveal
    const fields = document.querySelectorAll(
      ".form-fields > div, .form-fields > textarea, .form-fields > button",
    );

    // Create an intersection observer to trigger GSAP stagger when form is visible
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            gsap.fromTo(
              fields,
              { y: 30, opacity: 0 },
              {
                y: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.1,
                ease: "power3.out",
                force3D: true,
              },
            );
            observer.disconnect(); // Run once
          }
        });
      },
      { threshold: 0.2 },
    );

    if (fields.length > 0) {
      observer.observe(document.querySelector("#contact-form") as HTMLElement);
    }

    // 3. Magnetic Button CTA
    const btn = document.getElementById("magnetic-btn");
    const inner = btn?.querySelector(".magnetic-inner") as HTMLElement;

    if (
      btn &&
      inner &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      btn.addEventListener("mousemove", (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        // Move button slightly
        gsap.to(btn, {
          x: x * 0.2,
          y: y * 0.2,
          duration: 0.4,
          ease: "power2.out",
        });
        // Move inner text more
        gsap.to(inner, {
          x: x * 0.4,
          y: y * 0.4,
          duration: 0.4,
          ease: "power2.out",
        });
      });

      btn.addEventListener("mouseleave", () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 0.8,
          ease: "elastic.out(1, 0.3)",
        });
        gsap.to(inner, {
          x: 0,
          y: 0,
          duration: 0.8,
          ease: "elastic.out(1, 0.3)",
        });
      });
    }
  };

  initContactHub();
  document.addEventListener("astro:page-load", initContactHub);
</script>
