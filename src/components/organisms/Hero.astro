---
/**
 * Hero.astro — Organism
 * Adaptado para el sistema "Swiss Minimalism" (Tailwind v4 CSS-first).
 */
import { Image } from "astro:assets";
import Button from "@atoms/Button.astro";

interface Action {
  label: string;
  href: string;
  variant?: "primary" | "secondary" | "ghost" | "danger";
}

interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  content?: string;
  actions?: Action[];
  image?: string | any;
  id?: string;
  bg?: string;
}

const {
  title = await Astro.slots.render("title"),
  subtitle = await Astro.slots.render("subtitle"),
  tagline,
  content = await Astro.slots.render("content"),
  actions,
  image = await Astro.slots.render("image"),
  id,
  bg = await Astro.slots.render("bg"),
} = Astro.props;
---

<section
  class="relative md:-mt-[76px] not-prose overflow-hidden"
  {...id ? { id } : {}}
>
  <div class="absolute inset-0 pointer-events-none z-hide" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 z-base">
    <div class="pt-0 md:pt-[76px] pointer-events-none"></div>

    <div
      class="py-12 md:py-32 min-h-[80vh] flex flex-col items-center justify-center relative"
    >
      {
        image && (
          <div class="absolute inset-0 flex items-center justify-center z-hide opacity-80 pointer-events-none">
            <div class="relative w-full max-w-[800px] animate-pulse-slow">
              {typeof image === "string" ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class="mx-auto w-full h-auto"
                  widths={[400, 768, 1024]}
                  loading="eager"
                  width={1024}
                  height={1024}
                  src={image.src}
                  alt={image.alt || ""}
                  {...image}
                />
              )}
            </div>
          </div>
        )
      }

      <div class="text-center relative z-base max-w-5xl mx-auto">
        {
          tagline && (
            <div class="mb-8 flex justify-center">
              <span class="section-eyebrow" set:html={tagline} />
            </div>
          )
        }

        {
          title && (
            <h1
              class="font-display font-extrabold text-primary mb-8 text-center"
              style="font-size: clamp(3.5rem, 8vw, 6rem); letter-spacing: -0.04em; line-height: 1.05; text-wrap: balance;"
              set:html={title}
            />
          )
        }

        <div class="max-w-3xl mx-auto">
          {
            subtitle && (
              <p
                class="text-secondary text-xl font-medium leading-relaxed max-w-2xl mb-12 mx-auto text-center"
                style="text-wrap: balance;"
                set:html={subtitle}
              />
            )
          }

          {
            actions && (
              <div class="flex flex-col sm:flex-row sm:justify-center gap-4">
                {actions.map((action) => (
                  <div class="flex w-full sm:w-auto">
                    <Button
                      variant={action.variant || "primary"}
                      size="lg"
                      href={action.href}
                      class="w-full sm:w-auto px-8"
                    >
                      {action.label}
                    </Button>
                  </div>
                ))}
              </div>
            )
          }
        </div>
        {content && <div class="mt-8" set:html={content} />}
      </div>
    </div>
  </div>
</section>

<style>
  /* Animación sutil de respiración para el orbe como en la imagen */
  @keyframes pulse-slow {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.05);
      opacity: 0.9;
    }
  }
  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }
</style>
