---
/**
 * Icon.astro — Atom
 * Lightweight SVG icon wrapper. Accepts inline SVG string or
 * a named icon from the built-in library.
 * All icons are aria-hidden by default — label them at the parent level.
 */

type IconName =
  | 'check'
  | 'star'
  | 'arrow-right'
  | 'arrow-up-right'
  | 'chevron-down'
  | 'x'
  | 'plus'
  | 'minus'
  | 'zap'
  | 'target'
  | 'pen'
  | 'layout'
  | 'search'
  | 'message-circle'
  | 'clock'
  | 'shield'
  | 'trending-up'
  | 'smartphone'
  | 'globe'
  | 'mail'
  | 'phone'
  | 'map-pin'
  | 'instagram'
  | 'linkedin'
  | 'twitter'
  | 'whatsapp';

interface Props {
  /** Named icon from the built-in set */
  name?: IconName;
  /** Custom SVG string (overrides name) */
  svg?: string;
  /** Size in px or Tailwind size (default: 20) */
  size?: number | string;
  /** CSS color (inherits currentColor if not set) */
  color?: string;
  /** Additional classes */
  class?: string;
  /** Accessible label (makes it visible to AT) */
  label?: string;
}

const {
  name,
  svg: customSvg,
  size    = 20,
  color,
  class:  className,
  label,
} = Astro.props;

// Built-in icon paths — Feather/Lucide style, 24×24 viewBox
const icons: Record<IconName, string> = {
  'check':         '<polyline points="20 6 9 17 4 12"/>',
  'star':          '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
  'arrow-right':   '<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>',
  'arrow-up-right':'<line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>',
  'chevron-down':  '<polyline points="6 9 12 15 18 9"/>',
  'x':             '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
  'plus':          '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>',
  'minus':         '<line x1="5" y1="12" x2="19" y2="12"/>',
  'zap':           '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  'target':        '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  'pen':           '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>',
  'layout':        '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  'search':        '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  'message-circle':'<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  'clock':         '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  'shield':        '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  'trending-up':   '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  'smartphone':    '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
  'globe':         '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  'mail':          '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  'phone':         '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.4 19.79 19.79 0 0 1 1.61 4.8 2 2 0 0 1 3.6 2.6h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  'map-pin':       '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  'instagram':     '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  'linkedin':      '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  'twitter':       '<path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>',
  'whatsapp':      '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
};

const iconPaths = name ? icons[name] : undefined;
const sizeValue = typeof size === 'number' ? `${size}px` : size;
const colorStyle = color ? `color: ${color};` : '';
---

{customSvg ? (
  <span
    aria-hidden={!label ? 'true' : undefined}
    aria-label={label}
    role={label ? 'img' : undefined}
    class:list={['inline-flex items-center justify-center shrink-0', className]}
    style={`width:${sizeValue};height:${sizeValue};${colorStyle}`}
    set:html={customSvg}
  />
) : name && iconPaths ? (
  <svg
    aria-hidden={!label ? 'true' : undefined}
    aria-label={label}
    role={label ? 'img' : undefined}
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    class:list={['shrink-0', className]}
    style={`width:${sizeValue};height:${sizeValue};${colorStyle}`}
    set:html={iconPaths}
  />
) : null}