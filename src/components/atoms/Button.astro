---
/**
 * Button.astro — Atom (polymorphic)
 *
 * Audit fix [4]: Replaces `[key: string]: unknown` index signature with
 * proper discriminated union types. The component is strictly typed:
 * - When href is provided  → renders <a>  with HTMLAnchorElement attrs
 * - When href is absent    → renders <button> with HTMLButtonElement attrs
 * No `any` or `unknown` in the public API.
 *
 * Animation note: shimmer is CSS-only (no GSAP).
 * GSAP is reserved for scroll-triggered and interaction effects at
 * the Molecule/Organism level. This keeps atoms self-contained and
 * eliminates the CSS/JS animation fragmentation the audit identified.
 */

import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'secondary' | 'ghost' | 'danger';
type Size    = 'sm' | 'md' | 'lg';

// ── Shared props present on both button and anchor variants
interface SharedProps {
  variant?:      Variant;
  size?:         Size;
  disabled?:     boolean;
  loading?:      boolean;
  iconLeft?:     string;
  iconRight?:    string;
  fullWidth?:    boolean;
  class?:        string;
  'aria-label'?: string;
}

// ── When href is provided: anchor element semantics
interface AnchorProps extends SharedProps {
  href:      string;
  external?: boolean;
  // Anchor-specific HTML attrs (no `type`, no `form*`)
  download?: string;
  ping?:     string;
  // Discriminator: no `type` prop in anchor variant
  type?: never;
}

// ── When href is absent: button element semantics
interface ButtonProps extends SharedProps {
  href?:    never;
  external?: never;
  type?:    'button' | 'submit' | 'reset';
  // Button-specific HTML attrs
  form?:         string;
  formaction?:   string;
  formmethod?:   string;
  formnovalidate?: boolean;
  formtarget?:   string;
  name?:         string;
  value?:        string;
  autofocus?:    boolean;
}

// ── Union — Astro Props type must be a single object, so we use intersection + conditional
type Props = AnchorProps | ButtonProps;

const props = Astro.props as Props;

const {
  variant   = 'primary',
  size      = 'md',
  disabled  = false,
  loading   = false,
  iconLeft,
  iconRight,
  fullWidth = false,
  class: className,
  'aria-label': ariaLabel,
} = props;

// Type-narrowing helpers
const isAnchor   = (p: Props): p is AnchorProps => typeof (p as AnchorProps).href === 'string';
const href       = isAnchor(props) ? props.href : undefined;
const external   = isAnchor(props) ? (props.external ?? false) : false;
const buttonType = !isAnchor(props) ? ((props as ButtonProps).type ?? 'button') : undefined;

const isLink     = Boolean(href);
const isDisabled = disabled || loading;

// ── Variant styles
const variantMap: Record<Variant, string> = {
  primary: [
    'bg-brand-primary text-neutral-900',
    'hover:shadow-glow hover:brightness-110',
    'active:brightness-90 active:scale-[0.98]',
    'focus-visible:ring-2 focus-visible:ring-brand-primary',
    'focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900',
    'font-bold tracking-wide',
  ].join(' '),

  secondary: [
    'bg-transparent text-brand-primary',
    'border border-brand-primary/40',
    'hover:bg-brand-primary/8 hover:border-brand-primary hover:shadow-glow',
    'active:bg-brand-primary/12 active:scale-[0.98]',
    'focus-visible:ring-2 focus-visible:ring-brand-primary',
    'focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900',
  ].join(' '),

  ghost: [
    'bg-transparent text-secondary',
    'hover:text-primary hover:bg-surface-card',
    'active:bg-surface-card/60 active:scale-[0.98]',
    'focus-visible:ring-2 focus-visible:ring-neutral-400',
    'focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900',
  ].join(' '),

  danger: [
    'bg-semantic-error text-white',
    'hover:brightness-110 hover:shadow-[0_0_24px_rgba(255,59,92,0.35)]',
    'active:brightness-90 active:scale-[0.98]',
    'focus-visible:ring-2 focus-visible:ring-semantic-error',
    'focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900',
  ].join(' '),
};

// ── Size styles
const sizeMap: Record<Size, string> = {
  sm: 'h-8  px-4  text-xs   rounded-md  gap-1.5',
  md: 'h-11 px-6  text-sm   rounded-lg  gap-2',
  lg: 'h-14 px-8  text-base rounded-xl  gap-2.5',
};

// ── Spinner size
const spinnerSize: Record<Size, string> = { sm: '14px', md: '16px', lg: '18px' };

// ── Composed class list (array join avoids stray whitespace)
const classes = [
  'inline-flex items-center justify-center',
  'whitespace-nowrap select-none',
  'font-body font-medium',
  'transition-all duration-normal ease-standard',
  'relative overflow-hidden',
  sizeMap[size],
  variantMap[variant],
  fullWidth    ? 'w-full' : '',
  isDisabled   ? 'opacity-50 cursor-not-allowed pointer-events-none' : 'cursor-pointer',
  className    ?? '',
].filter(Boolean).join(' ');
---

{isLink ? (
  <a
    href={href}
    class={classes}
    aria-label={ariaLabel}
    aria-disabled={isDisabled ? 'true' : undefined}
    tabindex={isDisabled ? -1 : undefined}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener noreferrer' : undefined}
  >
    {variant === 'primary' && (
      <span aria-hidden="true" class="btn-shimmer" />
    )}
    {loading && <svg aria-hidden="true" class="animate-spin shrink-0" style={`width:${spinnerSize[size]};height:auto`} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>}
    {iconLeft && !loading && <span aria-hidden="true" class="shrink-0 text-[1.1em]" set:html={iconLeft} />}
    <slot />
    {iconRight && <span aria-hidden="true" class="shrink-0 text-[1.1em]" set:html={iconRight} />}
    {external && !iconRight && (
      <svg aria-hidden="true" class="shrink-0 opacity-60" style="width:12px;height:12px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15,3 21,3 21,9"/>
        <line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    )}
  </a>
) : (
  <button
    type={buttonType}
    class={classes}
    aria-label={ariaLabel}
    disabled={isDisabled}
    aria-disabled={isDisabled ? 'true' : undefined}
    aria-busy={loading ? 'true' : undefined}
  >
    {variant === 'primary' && (
      <span aria-hidden="true" class="btn-shimmer" />
    )}
    {loading && <svg aria-hidden="true" class="animate-spin shrink-0" style={`width:${spinnerSize[size]};height:auto`} xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>}
    {iconLeft && !loading && <span aria-hidden="true" class="shrink-0 text-[1.1em]" set:html={iconLeft} />}
    <slot />
    {iconRight && <span aria-hidden="true" class="shrink-0 text-[1.1em]" set:html={iconRight} />}
  </button>
)}

<style>
  /*
   * CSS-only shimmer — no GSAP needed for atoms.
   * Audit fix [4]: consolidates animation logic at CSS layer.
   * The parent <a> or <button> :hover triggers the child span transition.
   */
  .btn-shimmer {
    position:   absolute;
    inset:      0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    transform:  translateX(-120%);
    transition: transform 600ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  a:not([aria-disabled="true"]):hover .btn-shimmer,
  button:not(:disabled):hover .btn-shimmer {
    transform: translateX(120%);
  }
</style>