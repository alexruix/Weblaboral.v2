---
/**
 * ServiceCard.astro — Molecule
 * Identity: Swiss Minimalism + High-Fidelity Micro-interactions.
 * * Refactor Summary:
 * - CSS Variable Injection: Derives all states from a single --accent-color.
 * - Stretched Link Pattern: Maximum clickability with semantic integrity.
 * - Optimized GSAP: Transform-only animations with force3D acceleration.
 */
import Icon from "@atoms/Icon.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  icon: string;
  tag?: string;
  stat?: { value: string; label: string };
  href?: string;
  ctaText?: string;
  accent?: string; // Hex (ej: #0CF2D0)
  class?: string;
}

const {
  id,
  title,
  description,
  icon,
  tag,
  stat,
  href = "#",
  ctaText = "Explorar servicio",
  accent = "primary",
  class: className,
} = Astro.props;

const ACCENT_MAP: Record<string, string> = {
  primary: "var(--color-brand-primary)",
  secondary: "var(--color-semantic-info)",
  tertiary: "var(--color-brand-tertiary)",
};

const resolvedAccent = ACCENT_MAP[accent] || accent;
const headingId = `card-title-${id}`;
---

<article
  data-card
  class:list={[
    "group relative rounded-2xl overflow-hidden",
    "bg-surface-card/40 backdrop-blur-md border border-white/10",
    "transition-colors duration-500 hover:bg-surface-card/60",
    "will-change-transform",
    className,
  ]}
  style={`--accent-color: ${resolvedAccent};`}
  aria-labelledby={headingId}
>
  <div
    aria-hidden="true"
    data-spotlight
    class="absolute inset-0 opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-500"
    style="background: radial-gradient(600px circle at var(--x, 0px) var(--y, 0px), var(--accent-color), transparent 40%); filter: opacity(0.12);"
  >
  </div>

  <div class="relative z-10 p-8 flex flex-col h-full gap-8">
    <header class="flex items-start justify-between">
      <div
        aria-hidden="true"
        class="icon-box flex items-center justify-center w-14 h-14 rounded-xl shrink-0
          bg-[var(--accent-color)]/10 border border-[var(--accent-color)]/20 text-[var(--accent-color)]
          transition-all duration-500 ease-spring group-hover:scale-110 group-hover:shadow-[0_0_20px_var(--accent-color)]/20"
      >
        <div
          class="w-7 h-7 contents [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current"
          set:html={icon}
        />
      </div>

      {
        tag && (
          <span class="badge-base border-[var(--accent-color)]/30 text-[var(--accent-color)] bg-[var(--accent-color)]/5">
            {tag}
          </span>
        )
      }
    </header>

    <div class="flex-1 space-y-3">
      <h3
        id={headingId}
        class="font-display font-bold text-2xl tracking-tight text-text-primary group-hover:text-[var(--accent-color)] transition-colors duration-300"
      >
        {title}
      </h3>
      <p class="text-text-secondary text-base leading-relaxed max-w-[28ch]">
        {description}
      </p>
    </div>

    {
      stat && (
        <div class="pt-6 border-t border-white/5 space-y-1">
          <p class="font-display font-extrabold text-4xl text-[var(--accent-color)] drop-shadow-sm">
            {stat.value}
          </p>
          <p class="text-text-muted text-[10px] uppercase tracking-[0.2em] font-mono">
            {stat.label}
          </p>
        </div>
      )
    }

    <footer>
      <a
        href={href}
        class="stretched-link inline-flex items-center gap-2 text-sm font-bold text-[var(--accent-color)] hover:gap-4 transition-all duration-300"
      >
        {ctaText}
        <Icon name="arrow-right" size={18} />
      </a>
    </footer>
  </div>
</article>

<style>
  /* Stretched link pattern: Hace que toda la card sea clickable sin romper la semántica */
  .stretched-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 20;
  }

  /* Micro-interacción del icono */
  .icon-box :global(svg) {
    transition: transform 0.6s var(--ease-spring);
  }
  article:hover .icon-box :global(svg) {
    transform: rotate(-5deg) scale(1.1);
  }
</style>

<script>
  import gsap from "gsap";

  const initCards = () => {
    const cards = document.querySelectorAll<HTMLElement>("[data-card]");

    cards.forEach((card) => {
      const spotlight = card.querySelector<HTMLElement>("[data-spotlight]");
      let bounds: DOMRect;

      const updateBounds = () => {
        bounds = card.getBoundingClientRect();
      };

      const onMouseEnter = () => {
        updateBounds();
        gsap.to(card, {
          y: -4,
          duration: 0.4,
          ease: "power2.out",
          force3D: true,
        });
      };

      const onMouseMove = (e: MouseEvent) => {
        if (!bounds || !spotlight) return;

        // 1. Update Mesh Spotlight Position via CSS Vars
        const x = e.clientX - bounds.left;
        const y = e.clientY - bounds.top;
        card.style.setProperty("--x", `${x}px`);
        card.style.setProperty("--y", `${y}px`);

        // 2. High-Fidelity Tilt (force3D para aceleración GPU)
        const mouseX = (e.clientX - bounds.left) / bounds.width - 0.5;
        const mouseY = (e.clientY - bounds.top) / bounds.height - 0.5;

        gsap.to(card, {
          rotateY: mouseX * 6,
          rotateX: -mouseY * 6,
          duration: 0.6,
          ease: "power2.out",
          transformPerspective: 1000,
          force3D: true,
        });
      };

      const onMouseLeave = () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          y: 0,
          duration: 0.8,
          ease: "elastic.out(1, 0.85)", // Retorno orgánico no elástico
          force3D: true,
        });
      };

      // Desactivar si el usuario prefiere movimiento reducido (A11y)
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        card.addEventListener("mouseenter", onMouseEnter);
        card.addEventListener("mousemove", onMouseMove);
        card.addEventListener("mouseleave", onMouseLeave);
        window.addEventListener("resize", updateBounds);
      }
    });
  };

  // Soporte para Astro View Transitions
  initCards();
  document.addEventListener("astro:page-load", initCards);
</script>
