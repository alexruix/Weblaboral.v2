---
/**
 * TestimonialCard.astro — Molecule
 * Displays a client testimonial with avatar, quote, author details and rating.
 * Variants: 'default' | 'featured' (larger, with background emphasis)
 */

interface Props {
  /** Client quote (the testimonial text) */
  quote:       string;
  /** Full name of the client */
  author:      string;
  /** Job title / role */
  role:        string;
  /** Company name */
  company:     string;
  /** Avatar image URL (falls back to initials) */
  avatar?:     string;
  /** Star rating 1–5 (default 5) */
  rating?:     number;
  /** Featured variant — larger, highlighted */
  featured?:   boolean;
  /** Optional result/metric to highlight */
  result?:     { value: string; label: string };
  /** Accent color */
  accent?:     string;
  class?:      string;
}

const {
  quote,
  author,
  role,
  company,
  avatar,
  rating   = 5,
  featured = false,
  result,
  accent   = '#F5A623',
  class: className,
} = Astro.props;

// Generate initials from author name
const initials = author
  .split(' ')
  .map(n => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

const clampedRating = Math.min(5, Math.max(0, Math.round(rating)));
---

<figure
  class:list={[
    'group relative flex flex-col rounded-xl overflow-hidden',
    'transition-all duration-normal ease-standard',
    featured
      ? 'bg-surface-overlay border-2 p-8 md:p-10 shadow-glow'
      : 'bg-surface-card border border-surface p-6 hover:border-transparent',
    className,
  ]}
  style={featured ? `border-color: ${accent}40;` : ''}
>
  <!-- Glow overlay on hover (non-featured) -->
  {!featured && (
    <div
      aria-hidden="true"
      class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-normal pointer-events-none rounded-xl"
      style={`box-shadow: inset 0 0 0 1px ${accent}30; background: linear-gradient(135deg, ${accent}06, transparent);`}
    />
  )}

  <!-- Stars -->
  <div class="flex items-center gap-0.5 mb-4" aria-label={`${clampedRating} de 5 estrellas`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        aria-hidden="true"
        width="14" height="14"
        viewBox="0 0 24 24"
        fill={i < clampedRating ? accent : 'none'}
        stroke={i < clampedRating ? accent : 'currentColor'}
        stroke-width="2"
        class="opacity-90"
        style={i >= clampedRating ? 'opacity: 0.2;' : ''}
      >
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>

  <!-- Quote mark -->
  <div aria-hidden="true" class="mb-3 font-display font-extrabold text-5xl leading-none select-none" style={`color: ${accent}; line-height: 0.8;`}>
    "
  </div>

  <!-- Quote text -->
  <blockquote class:list={[
    'flex-1 text-secondary leading-relaxed mb-6',
    featured ? 'text-base' : 'text-sm',
  ]}>
    {quote}
  </blockquote>

  <!-- Result metric (optional) -->
  {result && (
    <div
      class="flex items-center gap-3 mb-5 px-4 py-3 rounded-lg"
      style={`background: ${accent}10; border: 1px solid ${accent}25;`}
    >
      <div>
        <p class="font-display font-extrabold text-xl" style={`color: ${accent};`}>
          {result.value}
        </p>
        <p class="text-muted text-xs font-mono tracking-wide">{result.label}</p>
      </div>
    </div>
  )}

  <!-- Author -->
  <figcaption class="flex items-center gap-3 mt-auto pt-4 border-t border-surface">
    <!-- Avatar -->
    <div class="relative shrink-0">
      {avatar ? (
        <img
          src={avatar}
          alt={`Foto de ${author}`}
          width="40"
          height="40"
          class="w-10 h-10 rounded-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="w-10 h-10 rounded-full flex items-center justify-center font-display font-bold text-sm"
          style={`background: ${accent}18; color: ${accent}; border: 1px solid ${accent}30;`}
          aria-hidden="true"
        >
          {initials}
        </div>
      )}
      <!-- Online indicator for featured -->
      {featured && (
        <span
          aria-hidden="true"
          class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-surface-overlay"
          style="background: var(--color-semantic-success);"
        />
      )}
    </div>

    <!-- Name + role -->
    <div class="min-w-0">
      <p class="font-semibold text-sm text-primary truncate">{author}</p>
      <p class="text-muted text-xs truncate">
        {role} · <span class="font-medium" style={`color: ${accent};`}>{company}</span>
      </p>
    </div>
  </figcaption>
</figure>